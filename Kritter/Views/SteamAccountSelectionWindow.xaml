<Window x:Class="Kritter.Views.SteamAccountSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:Kritter.Models"
        Title="CS2 Hesap Seçimi" Width="680" Height="520"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBrush}"
        ResizeMode="CanResizeWithGrip">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Counter-Strike 2 Steam Hesabı" FontSize="18" FontWeight="Bold"/>
            <TextBlock Text="`userdata` içinde 730 klasörü bulunan hesabı seçin. Seçilen hesabın CS2 ayarları `.kritter` paketine eklenecek."
                       Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,6,0,0"/>
        </StackPanel>

        <ListBox Grid.Row="1"
                 ItemsSource="{Binding Accounts}"
                 SelectedItem="{Binding SelectedAccount}"
                 BorderThickness="0"
                 Background="Transparent">
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type models:SteamUserAccount}">
                    <Border Margin="0,0,0,10" Padding="12"
                            Background="{StaticResource CardBrush}" CornerRadius="8"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="68"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Width="56" Height="56" CornerRadius="8" Background="{StaticResource PanelBrush}">
                                <Image Source="{Binding AvatarUrl}" Stretch="UniformToFill"/>
                            </Border>

                            <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                <TextBlock Text="{Binding DisplayName}" FontSize="15" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding DisplaySubtitle}" Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,4,0,2"/>
                                <TextBlock Text="{Binding SteamId64}" FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>

                            <Border Grid.Column="2" Padding="8,4" Margin="10,0,0,0"
                                    Background="{StaticResource PanelBrush}" CornerRadius="6"
                                    VerticalAlignment="Top"
                                    Visibility="{Binding IsMostRecent, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="Son kullanılan" FontSize="11" Foreground="{StaticResource AccentBrush}"/>
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="İptal" Style="{StaticResource GhostButton}" Margin="0,0,8,0"
                    Click="Cancel_Click" Padding="24,10"/>
            <Button Content="Hesabı Kullan" Style="{StaticResource AccentButton}"
                    Click="OK_Click" Padding="24,10"/>
        </StackPanel>
    </Grid>
</Window>
