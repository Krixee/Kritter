<UserControl x:Class="Kritter.Views.FormatAtView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:Kritter.Localization"
             xmlns:models="clr-namespace:Kritter.Models"
             Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,26">
        <StackPanel MaxWidth="980">
            <Border Style="{StaticResource HeroCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock Text="{x:Static loc:AppText.FormatPageTitle}" Style="{StaticResource PageTitleText}"/>
                            <TextBlock Text="{x:Static loc:AppText.FormatPageSubtitle}"
                                       Style="{StaticResource PageSubtitleText}" Margin="0,8,0,0" MaxWidth="700"/>
                        </StackPanel>

                        <Button Content="{x:Static loc:AppText.ScanSystem}" Style="{StaticResource AccentButton}"
                                Command="{Binding ScanCommand}" HorizontalAlignment="Right"
                                Visibility="{Binding ShowScanButton, Converter={StaticResource BoolToVis}}"/>
                    </DockPanel>

                    <WrapPanel Grid.Row="1" Margin="0,22,0,4">
                        <Border Style="{StaticResource MetricCard}" Width="180">
                            <StackPanel>
                                <TextBlock Text="{x:Static loc:AppText.InstalledAppsMetric}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                                <TextBlock Text="{Binding InstalledApps.Count}" FontFamily="{StaticResource HeadingFont}" FontSize="28"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource MetricCard}" Width="180">
                            <StackPanel>
                                <TextBlock Text="{x:Static loc:AppText.SetupFilesMetric}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                                <TextBlock Text="{Binding SetupInstallers.Count}" FontFamily="{StaticResource HeadingFont}" FontSize="28"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource MetricCard}" Width="180">
                            <StackPanel>
                                <TextBlock Text="{x:Static loc:AppText.GameBackupsMetric}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                                <TextBlock Text="{Binding GameSettingsBackups.Count}" FontFamily="{StaticResource HeadingFont}" FontSize="28"/>
                            </StackPanel>
                        </Border>
                    </WrapPanel>

                    <StackPanel Grid.Row="2">
                        <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource AccentBrush}"
                                   FontSize="13" Margin="0,8,0,0"
                                   Visibility="{Binding StatusText, Converter={StaticResource NullToVis}}"/>

                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0"
                                    Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="..." FontSize="18" Margin="0,0,8,0"/>
                            <TextBlock Text="{x:Static loc:AppText.ScanningSystem}" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <StackPanel Visibility="{Binding ScanComplete, Converter={StaticResource BoolToVis}}">
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,12">
                            <StackPanel DockPanel.Dock="Left">
                                <TextBlock Text="{x:Static loc:AppText.DetectedAppsTitle}" FontFamily="{StaticResource HeadingFont}" FontSize="18"/>
                                <TextBlock Text="{x:Static loc:AppText.DetectedAppsSubtitle}"
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="{x:Static loc:AppText.SelectAll}" Style="{StaticResource GhostButton}"
                                        Command="{Binding SelectAllInstalledCommand}" Margin="0,0,8,0"/>
                                <Button Content="{x:Static loc:AppText.Clear}" Style="{StaticResource GhostButton}"
                                        Command="{Binding DeselectAllInstalledCommand}"/>
                            </StackPanel>
                        </DockPanel>

                        <TextBlock Text="{x:Static loc:AppText.NoDetectedApps}"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"
                                   Visibility="{Binding InstalledApps.Count, Converter={StaticResource CountToVis}, ConverterParameter=Invert}"/>

                        <ItemsControl ItemsSource="{Binding InstalledApps}" MaxHeight="280"
                                      Visibility="{Binding InstalledApps.Count, Converter={StaticResource CountToVis}}">
                            <ItemsControl.Template>
                                <ControlTemplate TargetType="ItemsControl">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </ControlTemplate>
                            </ItemsControl.Template>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:WingetApp}">
                                    <Border Style="{StaticResource MetricCard}" Margin="0,0,0,10">
                                        <CheckBox IsChecked="{Binding IsSelected}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Name}" Margin="0,0,10,0"/>
                                                <Border Style="{StaticResource InfoPill}" Margin="0,0,8,0">
                                                    <TextBlock Text="{Binding MethodLabel}" FontSize="10" Foreground="{StaticResource AccentBrush}"/>
                                                </Border>
                                                <TextBlock Text="{Binding Id}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                                            </StackPanel>
                                        </CheckBox>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionCard}"
                        Visibility="{Binding CommonApps.Count, Converter={StaticResource CountToVis}}">
                    <StackPanel>
                        <TextBlock Text="{x:Static loc:AppText.CommonAppsTitle}" FontFamily="{StaticResource HeadingFont}" FontSize="18"/>
                        <TextBlock Text="{x:Static loc:AppText.CommonAppsSubtitle}"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,14"/>

                        <ItemsControl ItemsSource="{Binding CommonApps}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel ItemWidth="240"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:WingetApp}">
                                    <Border Style="{StaticResource MetricCard}" Width="224">
                                        <CheckBox IsChecked="{Binding IsSelected}">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding MethodLabel}" FontSize="11" Foreground="{StaticResource AccentBrush}" Margin="0,6,0,0"/>
                                            </StackPanel>
                                        </CheckBox>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="{x:Static loc:AppText.SetupFilesTitle}" FontFamily="{StaticResource HeadingFont}" FontSize="18"/>
                        <TextBlock Text="{x:Static loc:AppText.SetupFilesSubtitle}"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,12"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Button Content="{x:Static loc:AppText.SelectSetupFolder}" Style="{StaticResource GhostButton}"
                                    Command="{Binding SelectSetupFolderCommand}"/>
                            <Border Style="{StaticResource InfoPill}" Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding SetupFolderPath}" Foreground="{StaticResource TextSecondaryBrush}"
                                           Width="520" TextTrimming="CharacterEllipsis"/>
                            </Border>
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding SetupInstallers}"
                                      Visibility="{Binding SetupInstallers.Count, Converter={StaticResource CountToVis}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:SetupInstaller}">
                                    <Border Style="{StaticResource MetricCard}" Margin="0,0,0,10">
                                        <CheckBox IsChecked="{Binding IsSelected}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding DisplayFileName}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                                </StackPanel>
                                                <Border Grid.Column="1" Style="{StaticResource InfoPill}">
                                                    <TextBlock Text="{Binding MethodLabel}" FontSize="10" Foreground="{StaticResource AccentBrush}"/>
                                                </Border>
                                            </Grid>
                                        </CheckBox>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="{x:Static loc:AppText.GameSettingsTitle}" FontFamily="{StaticResource HeadingFont}" FontSize="18"/>
                        <TextBlock Text="{x:Static loc:AppText.GameSettingsSubtitle1}"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,4"/>
                        <TextBlock Text="{x:Static loc:AppText.GameSettingsSubtitle2}"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>

                        <Button Content="{x:Static loc:AppText.SelectCs2Account}" Style="{StaticResource GhostButton}"
                                Command="{Binding SelectCs2AccountCommand}" HorizontalAlignment="Left" Margin="0,0,0,12"/>

                        <ItemsControl ItemsSource="{Binding GameSettingsBackups}"
                                      Visibility="{Binding GameSettingsBackups.Count, Converter={StaticResource CountToVis}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:GameSettingsBackup}">
                                    <Border Style="{StaticResource MetricCard}" Margin="0,0,0,10">
                                        <CheckBox IsChecked="{Binding IsSelected}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding DisplayDetails}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                                </StackPanel>
                                                <Border Grid.Column="1" Style="{StaticResource InfoPill}">
                                                    <TextBlock Text="CS2" FontSize="10" Foreground="{StaticResource AccentBrush}"/>
                                                </Border>
                                            </Grid>
                                        </CheckBox>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="{x:Static loc:AppText.OptimizationModeTitle}" FontFamily="{StaticResource HeadingFont}" FontSize="18" Margin="0,0,0,12"/>

                        <RadioButton Style="{StaticResource OptionRadio}" GroupName="OptMode"
                                     Content="{x:Static loc:AppText.KritterRecommended}"
                                     IsChecked="{Binding SelectedMode, Converter={StaticResource EnumToBool}, ConverterParameter=KritterRecommended}"/>

                        <DockPanel Margin="0,6">
                            <RadioButton Style="{StaticResource OptionRadio}" GroupName="OptMode"
                                         Content="{x:Static loc:AppText.Fr33tyAll}" DockPanel.Dock="Left"
                                         IsChecked="{Binding SelectedMode, Converter={StaticResource EnumToBool}, ConverterParameter=Fr33tyAll}"/>
                        </DockPanel>

                        <Button Content="{x:Static loc:AppText.SelectScripts}" Style="{StaticResource GhostButton}"
                                Command="{Binding ShowFr33tyModalCommand}" HorizontalAlignment="Left"
                                Margin="30,0,0,6"
                                Visibility="{Binding IsFr33tyMode, Converter={StaticResource BoolToVis}}"/>

                        <RadioButton Style="{StaticResource OptionRadio}" GroupName="OptMode"
                                     Content="{x:Static loc:AppText.KeepCurrent}"
                                     IsChecked="{Binding SelectedMode, Converter={StaticResource EnumToBool}, ConverterParameter=KeepCurrent}"/>
                    </StackPanel>
                </Border>

                <Button Content="{x:Static loc:AppText.CreatePackage}" Style="{StaticResource AccentButton}"
                        Command="{Binding CreatePackageCommand}" HorizontalAlignment="Left"
                        Margin="0,4,0,26" FontSize="15" Padding="34,14"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
