<UserControl x:Class="Kritter.Views.FormatAtView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:Kritter.Models"
             Background="{StaticResource BgBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32,24">
        <StackPanel MaxWidth="780">
            <TextBlock Text="Format At" FontSize="22" FontWeight="Bold" Margin="0,0,0,4"/>
            <TextBlock Text="Sisteminizi tarayın, uygulamalarınızı ve optimizasyon modunu seçin."
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,20"/>

            <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource AccentBrush}"
                       FontSize="13" Margin="0,0,0,12"
                       Visibility="{Binding StatusText, Converter={StaticResource NullToVis}}"/>

            <Button Content="Sistemi Tara" Style="{StaticResource AccentButton}"
                    Command="{Binding ScanCommand}" HorizontalAlignment="Left" Margin="0,0,0,16"
                    Visibility="{Binding ShowScanButton, Converter={StaticResource BoolToVis}}"/>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,16"
                        Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="&#x23F3;" FontSize="16" Margin="0,0,8,0"/>
                <TextBlock Text="Sistem taranıyor..." Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>

            <StackPanel Visibility="{Binding ScanComplete, Converter={StaticResource BoolToVis}}">

                <!-- Installed Apps -->
                <Border Background="{StaticResource CardBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,16"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,10">
                            <TextBlock Text="Tespit Edilen Uygulamalar" FontSize="15" FontWeight="SemiBold"
                                       DockPanel.Dock="Left"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="Tümünü Seç" Style="{StaticResource GhostButton}"
                                        Command="{Binding SelectAllInstalledCommand}" Margin="0,0,6,0"/>
                                <Button Content="Temizle" Style="{StaticResource GhostButton}"
                                        Command="{Binding DeselectAllInstalledCommand}"/>
                            </StackPanel>
                        </DockPanel>

                        <TextBlock Text="Tespit edilen uygulama yok."
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"
                                   Visibility="{Binding InstalledApps.Count, Converter={StaticResource CountToVis}, ConverterParameter=Invert}"/>

                        <ItemsControl ItemsSource="{Binding InstalledApps}" MaxHeight="260"
                                      Visibility="{Binding InstalledApps.Count, Converter={StaticResource CountToVis}}">
                            <ItemsControl.Template>
                                <ControlTemplate TargetType="ItemsControl">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </ControlTemplate>
                            </ItemsControl.Template>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:WingetApp}">
                                    <CheckBox IsChecked="{Binding IsSelected}" Margin="0,3">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Name}" Margin="0,0,10,0"/>
                                            <Border Background="{StaticResource PanelBrush}" CornerRadius="4" Padding="6,1" Margin="0,0,8,0">
                                                <TextBlock Text="{Binding MethodLabel}" FontSize="10" Foreground="{StaticResource AccentBrush}"/>
                                            </Border>
                                            <TextBlock Text="{Binding Id}" Foreground="{StaticResource TextSecondaryBrush}"
                                                       FontSize="11"/>
                                        </StackPanel>
                                    </CheckBox>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Common Apps -->
                <Border Background="{StaticResource CardBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,16"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                        Visibility="{Binding CommonApps.Count, Converter={StaticResource CountToVis}}">
                    <StackPanel>
                        <TextBlock Text="Yaygın Uygulamalar" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBlock Text="Şu anda yüklü değil, pakete ekleyebilirsiniz."
                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,10"/>

                        <ItemsControl ItemsSource="{Binding CommonApps}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel ItemWidth="230"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:WingetApp}">
                                    <Border Width="220" Margin="0,4,10,4" Padding="10,8"
                                            Background="{StaticResource PanelBrush}" CornerRadius="6"
                                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                        <CheckBox IsChecked="{Binding IsSelected}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Name}" TextWrapping="Wrap" Margin="0,0,8,0"/>
                                                <TextBlock Text="{Binding MethodLabel}" FontSize="10" Foreground="{StaticResource AccentBrush}"/>
                                            </StackPanel>
                                        </CheckBox>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Setup Folder Section -->
                <Border Background="{StaticResource CardBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,16"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Setup Dosyaları" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <TextBlock Text="Driver'ları manuel kurmanız önerilir. Lütfen seçtiğiniz klasörde driver kurulum dosyaları varsa çıkarın."
                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,10"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Button Content="Setup klasörü seç" Style="{StaticResource GhostButton}"
                                    Command="{Binding SelectSetupFolderCommand}"/>
                            <TextBlock Text="{Binding SetupFolderPath}" Margin="12,6,0,0"
                                       Foreground="{StaticResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis"
                                       Width="500"/>
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding SetupInstallers}"
                                      Visibility="{Binding SetupInstallers.Count, Converter={StaticResource CountToVis}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:SetupInstaller}">
                                    <Border Margin="0,4,0,4" Padding="10,8" Background="{StaticResource PanelBrush}"
                                            CornerRadius="6" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                        <CheckBox IsChecked="{Binding IsSelected}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding DisplayName}" FontSize="13" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding DisplayFileName}" FontSize="11"
                                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                                </StackPanel>
                                                <Border Grid.Column="1" Background="{StaticResource CardBrush}" CornerRadius="4"
                                                        Padding="8,2" Margin="8,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding MethodLabel}" FontSize="10" Foreground="{StaticResource AccentBrush}"/>
                                                </Border>
                                            </Grid>
                                        </CheckBox>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Optimization Mode -->
                <Border Background="{StaticResource CardBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,16"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Optimizasyon Modu" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12"/>

                        <RadioButton Style="{StaticResource OptionRadio}" GroupName="OptMode"
                                     Content="Kritter Önerilen"
                                     IsChecked="{Binding SelectedMode, Converter={StaticResource EnumToBool}, ConverterParameter=KritterRecommended}"/>

                        <DockPanel Margin="0,4">
                            <RadioButton Style="{StaticResource OptionRadio}" GroupName="OptMode"
                                         Content="Fr33ty Tüm Optimizasyon" DockPanel.Dock="Left"
                                         IsChecked="{Binding SelectedMode, Converter={StaticResource EnumToBool}, ConverterParameter=Fr33tyAll}"/>
                        </DockPanel>

                        <Button Content="Scriptleri Seç..." Style="{StaticResource GhostButton}"
                                Command="{Binding ShowFr33tyModalCommand}" HorizontalAlignment="Left"
                                Margin="30,0,0,4"
                                Visibility="{Binding IsFr33tyMode, Converter={StaticResource BoolToVis}}"/>

                        <RadioButton Style="{StaticResource OptionRadio}" GroupName="OptMode"
                                     Content="Şu anki ayarları koru"
                                     IsChecked="{Binding SelectedMode, Converter={StaticResource EnumToBool}, ConverterParameter=KeepCurrent}"/>
                    </StackPanel>
                </Border>

                <Button Content="Paketi Oluştur" Style="{StaticResource AccentButton}"
                        Command="{Binding CreatePackageCommand}"
                        HorizontalAlignment="Left" Margin="0,4,0,24"
                        FontSize="15" Padding="32,12"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
