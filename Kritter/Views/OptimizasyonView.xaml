<UserControl x:Class="Kritter.Views.OptimizasyonView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:Kritter.Models"
             Background="Transparent">

    <Grid Margin="28,26">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource HeroCard}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Optimizasyon" Style="{StaticResource PageTitleText}"/>
                    <TextBlock Text="Kritter veya Fr33ty akışlarını seçin, scriptleri yönetin ve sistemi doğrudan uygulama içinden optimize edin."
                               Style="{StaticResource PageSubtitleText}" Margin="0,8,0,0" MaxWidth="700"/>

                    <WrapPanel Margin="0,20,0,0">
                        <Border Style="{StaticResource MetricCard}" Width="180">
                            <StackPanel>
                                <TextBlock Text="Kritter Scripts" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                                <TextBlock Text="{Binding KritterScripts.Count}" FontFamily="{StaticResource HeadingFont}" FontSize="28"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource MetricCard}" Width="180">
                            <StackPanel>
                                <TextBlock Text="Fr33ty Selected" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                                <TextBlock Text="{Binding SelectedFr33tyScripts.Count}" FontFamily="{StaticResource HeadingFont}" FontSize="28"/>
                            </StackPanel>
                        </Border>
                    </WrapPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" VerticalAlignment="Top">
                    <Button Content="Optimizasyonu Uygula" Style="{StaticResource AccentButton}"
                            Command="{Binding ApplyCommand}" FontSize="15" Padding="32,14"
                            IsEnabled="{Binding CanApply}"/>
                    <TextBlock Text="{Binding CurrentStepText}" Width="220" TextWrapping="Wrap"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,12,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <TextBlock Grid.Row="1" Text="{Binding StatusText}" Foreground="{StaticResource AccentBrush}"
                   FontSize="13" Margin="0,0,0,12"
                   Visibility="{Binding StatusText, Converter={StaticResource NullToVis}}"/>

        <StackPanel Grid.Row="2">
            <Border Style="{StaticResource SectionCard}">
                <StackPanel>
                    <TextBlock Text="Optimizasyon Modu" FontFamily="{StaticResource HeadingFont}" FontSize="18" Margin="0,0,0,12"/>

                    <RadioButton Style="{StaticResource OptionRadio}" GroupName="OptMode"
                                 Content="Kritter Önerilen"
                                 IsChecked="{Binding SelectedMode, Converter={StaticResource EnumToBool}, ConverterParameter=KritterRecommended}"/>

                    <DockPanel Margin="0,6">
                        <RadioButton Style="{StaticResource OptionRadio}" GroupName="OptMode"
                                     Content="Fr33ty Tüm Optimizasyon" DockPanel.Dock="Left"
                                     IsChecked="{Binding SelectedMode, Converter={StaticResource EnumToBool}, ConverterParameter=Fr33tyAll}"/>
                    </DockPanel>

                    <Button Content="Scriptleri Seç..." Style="{StaticResource GhostButton}"
                            Command="{Binding ShowFr33tyModalCommand}" HorizontalAlignment="Left"
                            Margin="30,0,0,6"
                            Visibility="{Binding IsFr33tyMode, Converter={StaticResource BoolToVis}}"/>

                    <TextBlock Text="{Binding SelectedFr33tyScripts.Count, StringFormat='{}{0} script seçildi'}"
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="30,0,0,4"
                               Visibility="{Binding IsFr33tyMode, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionCard}"
                    Visibility="{Binding IsKritterMode, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <DockPanel Margin="0,0,0,12">
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock Text="Scriptler" FontFamily="{StaticResource HeadingFont}" FontSize="18"/>
                            <TextBlock Text="Kritter önerilen script listesi."
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Tümünü Seç" Style="{StaticResource GhostButton}"
                                    Command="{Binding SelectAllCommand}" Margin="0,0,8,0"/>
                            <Button Content="Temizle" Style="{StaticResource GhostButton}"
                                    Command="{Binding DeselectAllCommand}"/>
                        </StackPanel>
                    </DockPanel>

                    <ItemsControl ItemsSource="{Binding KritterScripts}" MaxHeight="260">
                        <ItemsControl.Template>
                            <ControlTemplate TargetType="ItemsControl">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                    <ItemsPresenter/>
                                </ScrollViewer>
                            </ControlTemplate>
                        </ItemsControl.Template>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:OptimizationScript}">
                                <Border Style="{StaticResource MetricCard}" Margin="0,0,0,10">
                                    <CheckBox IsChecked="{Binding IsSelected}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding DisplayName}" Margin="0,0,10,0"/>
                                            <Border Style="{StaticResource InfoPill}">
                                                <TextBlock Text="{Binding Category}" FontSize="10" Foreground="{StaticResource AccentBrush}"/>
                                            </Border>
                                        </StackPanel>
                                    </CheckBox>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>

        <Border Grid.Row="3" Style="{StaticResource SectionCard}">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                    <TextBlock Text="İşlem Günlüğü" FontFamily="{StaticResource HeadingFont}" FontSize="18"/>
                    <TextBlock Text="Uygulanan veya atlanan tüm optimizasyon adımları burada görünür."
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>
                <ListBox x:Name="LogList" ItemsSource="{Binding LogEntries}"
                         Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         FontFamily="{StaticResource MonoFont}"
                         FontSize="12" Foreground="{StaticResource TextBrush}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" TextWrapping="Wrap" Margin="0,2"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,8,0,0"
                    Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}">
            <Border Style="{StaticResource InfoPill}">
                <TextBlock Text="Optimization Running" FontSize="11" Foreground="{StaticResource AccentBrush}"/>
            </Border>
            <TextBlock Text="Optimizasyon devam ediyor..." Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="10,2,0,0"/>
        </StackPanel>
    </Grid>
</UserControl>
