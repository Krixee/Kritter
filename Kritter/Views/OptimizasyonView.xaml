<UserControl x:Class="Kritter.Views.OptimizasyonView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:Kritter.Models"
             Background="{StaticResource BgBrush}">

    <Grid Margin="32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Page Title -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Optimizasyon" FontSize="22" FontWeight="Bold" Margin="0,0,0,4"/>
            <TextBlock Text="Optimizasyon modunu seçin, scriptleri belirleyin ve doğrudan uygulayın."
                       Foreground="{StaticResource TextSecondaryBrush}"/>
        </StackPanel>

        <!-- Status -->
        <TextBlock Grid.Row="1" Text="{Binding StatusText}" Foreground="{StaticResource AccentBrush}"
                   FontSize="13" Margin="0,0,0,12"
                   Visibility="{Binding StatusText, Converter={StaticResource NullToVis}}"/>

        <!-- Optimization Mode Selection -->
        <Border Grid.Row="2" Background="{StaticResource CardBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,16"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Optimizasyon Modu" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12"/>

                <RadioButton Style="{StaticResource OptionRadio}" GroupName="OptMode"
                             Content="Kritter Önerilen"
                             IsChecked="{Binding SelectedMode, Converter={StaticResource EnumToBool}, ConverterParameter=KritterRecommended}"/>

                <DockPanel Margin="0,4">
                    <RadioButton Style="{StaticResource OptionRadio}" GroupName="OptMode"
                                 Content="Fr33ty Tüm Optimizasyon" DockPanel.Dock="Left"
                                 IsChecked="{Binding SelectedMode, Converter={StaticResource EnumToBool}, ConverterParameter=Fr33tyAll}"/>
                </DockPanel>

                <Button Content="Scriptleri Seç..." Style="{StaticResource GhostButton}"
                        Command="{Binding ShowFr33tyModalCommand}" HorizontalAlignment="Left"
                        Margin="30,0,0,4"
                        Visibility="{Binding IsFr33tyMode, Converter={StaticResource BoolToVis}}"/>

                <TextBlock Text="{Binding SelectedFr33tyScripts.Count, StringFormat='{}{0} script seçildi'}"
                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="30,0,0,4"
                           Visibility="{Binding IsFr33tyMode, Converter={StaticResource BoolToVis}}"/>
            </StackPanel>
        </Border>

        <!-- Kritter Scripts List -->
        <Border Grid.Row="3" Background="{StaticResource CardBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,16"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                Visibility="{Binding IsKritterMode, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <DockPanel Margin="0,0,0,10">
                    <TextBlock Text="Scriptler" FontSize="15" FontWeight="SemiBold" DockPanel.Dock="Left"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Tümünü Seç" Style="{StaticResource GhostButton}"
                                Command="{Binding SelectAllCommand}" Margin="0,0,6,0"/>
                        <Button Content="Temizle" Style="{StaticResource GhostButton}"
                                Command="{Binding DeselectAllCommand}"/>
                    </StackPanel>
                </DockPanel>

                <ItemsControl ItemsSource="{Binding KritterScripts}" MaxHeight="220">
                    <ItemsControl.Template>
                        <ControlTemplate TargetType="ItemsControl">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <ItemsPresenter/>
                            </ScrollViewer>
                        </ControlTemplate>
                    </ItemsControl.Template>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:OptimizationScript}">
                            <CheckBox IsChecked="{Binding IsSelected}" Margin="0,3">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding DisplayName}" Margin="0,0,10,0"/>
                                    <Border Background="{StaticResource PanelBrush}" CornerRadius="4" Padding="6,1">
                                        <TextBlock Text="{Binding Category}" FontSize="10"
                                                   Foreground="{StaticResource AccentBrush}"/>
                                    </Border>
                                </StackPanel>
                            </CheckBox>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- Apply Button -->
        <DockPanel Grid.Row="4" Margin="0,0,0,16">
            <Button Content="Optimizasyonu Uygula" Style="{StaticResource AccentButton}"
                    Command="{Binding ApplyCommand}" DockPanel.Dock="Left"
                    FontSize="15" Padding="32,12"
                    IsEnabled="{Binding CanApply}"/>
            <TextBlock Text="{Binding CurrentStepText}" VerticalAlignment="Center"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="16,0,0,0"
                       FontSize="12"/>
        </DockPanel>

        <!-- Log Area -->
        <Border Grid.Row="5" Background="{StaticResource CardBrush}" CornerRadius="8"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                Padding="12">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="İşlem Günlüğü" FontSize="13"
                           FontWeight="SemiBold" Margin="0,0,0,8"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
                <ListBox x:Name="LogList" ItemsSource="{Binding LogEntries}"
                         Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         FontFamily="Cascadia Mono, Consolas, Courier New"
                         FontSize="12" Foreground="{StaticResource TextBrush}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" TextWrapping="Wrap" Margin="0,1"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Running indicator -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" Margin="0,8,0,0"
                    Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="&#x23F3;" FontSize="14" Margin="0,0,6,0"/>
            <TextBlock Text="Optimizasyon devam ediyor..." Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
        </StackPanel>
    </Grid>
</UserControl>
