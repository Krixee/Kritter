<UserControl x:Class="Kritter.Views.InfoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:Kritter.Localization"
             Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,26">
        <StackPanel MaxWidth="920">
            <Border Style="{StaticResource HeroCard}">
                <StackPanel>
                    <TextBlock Text="{x:Static loc:AppText.InfoPageTitle}" Style="{StaticResource PageTitleText}"/>
                    <TextBlock Text="{x:Static loc:AppText.InfoPageSubtitle}"
                               Style="{StaticResource PageSubtitleText}" Margin="0,8,0,0"/>
                    <TextBlock Text="{x:Static loc:AppText.InfoVersionBody}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,12,0,0"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionCard}">
                <StackPanel>
                    <TextBlock Text="{x:Static loc:AppText.InfoCard1Title}" FontFamily="{StaticResource HeadingFont}" FontSize="18"/>
                    <TextBlock Text="{x:Static loc:AppText.InfoCard1Body}" Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,8,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionCard}">
                <StackPanel>
                    <TextBlock Text="{x:Static loc:AppText.InfoCard2Title}" FontFamily="{StaticResource HeadingFont}" FontSize="18"/>
                    <TextBlock Text="{x:Static loc:AppText.InfoCard2Body}" Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,8,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionCard}">
                <StackPanel>
                    <TextBlock Text="{x:Static loc:AppText.InfoCard3Title}" FontFamily="{StaticResource HeadingFont}" FontSize="18"/>
                    <TextBlock Text="{x:Static loc:AppText.InfoCard3Body}" Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,8,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
