<Window x:Class="Kritter.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Kritter.ViewModels"
        xmlns:views="clr-namespace:Kritter.Views"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Kritter" Width="960" Height="640"
        MinWidth="800" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Icon="/Assets/icon.ico"
        Background="{StaticResource BgBrush}">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40"
                            ResizeBorderThickness="6"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Border Background="{StaticResource BgBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Custom Title Bar -->
            <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                <Grid Height="40" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Kritter" FontSize="14" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="14,0,0,0"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button Content="_" Style="{StaticResource TitleBarButton}" Click="MinimizeButton_Click"/>
                        <Button Content="X" Style="{StaticResource TitleBarCloseButton}" Click="CloseButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Main Layout -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Sidebar -->
                <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Margin="16,20,16,18">
                            <TextBlock Text="Kritter" FontSize="22" FontWeight="Bold"
                                       Foreground="{StaticResource AccentBrush}"/>
                            <TextBlock Text="v1.0" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>

                        <StackPanel DockPanel.Dock="Bottom" Margin="12,0,12,12">
                            <Border Background="{StaticResource PanelBrush}" CornerRadius="8" Padding="12"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="Info" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"
                                               Foreground="{StaticResource AccentBrush}"/>
                                    <TextBlock Text="Yapımcı: Krixe" FontSize="12" Margin="0,0,0,4"/>
                                    <TextBlock Text="Uyarı: Optimizasyonlar sistem ayarlarını değiştirir; uygulamadan önce geri yükleme noktası önerilir."
                                               FontSize="11" TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                    <TextBlock Text="Genel olarak arka plan yükünü azaltır, servis/başlangıç yapılandırmasını düzenler ve oyun performansını iyileştirmeyi hedefler."
                                               FontSize="11" TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="Windows Optimization &amp; Setup"
                                       FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" Opacity="0.7"/>
                        </StackPanel>

                        <StackPanel Margin="8,0">
                            <RadioButton Style="{StaticResource NavButton}" Content="Format At"
                                         IsChecked="{Binding SelectedPageIndex, Converter={StaticResource EnumToBool}, ConverterParameter=0}"
                                         Command="{Binding NavigateFormatAtCommand}"/>
                            <RadioButton Style="{StaticResource NavButton}" Content="Yükle"
                                         IsChecked="{Binding SelectedPageIndex, Converter={StaticResource EnumToBool}, ConverterParameter=1}"
                                         Command="{Binding NavigateYukleCommand}"/>
                            <RadioButton Style="{StaticResource NavButton}" Content="Optimizasyon"
                                         IsChecked="{Binding SelectedPageIndex, Converter={StaticResource EnumToBool}, ConverterParameter=2}"
                                         Command="{Binding NavigateOptimizasyonCommand}"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Content Area -->
                <ContentControl Grid.Column="1" Content="{Binding CurrentPage}" Margin="0">
                    <ContentControl.Resources>
                        <DataTemplate DataType="{x:Type vm:FormatAtViewModel}">
                            <views:FormatAtView/>
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:YukleViewModel}">
                            <views:YukleView/>
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:OptimizasyonViewModel}">
                            <views:OptimizasyonView/>
                        </DataTemplate>
                    </ContentControl.Resources>
                </ContentControl>
            </Grid>
        </Grid>
    </Border>
</Window>
