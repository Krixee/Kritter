<Window x:Class="Kritter.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:Kritter.Localization"
        xmlns:vm="clr-namespace:Kritter.ViewModels"
        xmlns:views="clr-namespace:Kritter.Views"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Kritter" Width="1280" Height="820"
        MinWidth="1080" MinHeight="680"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Icon="/Assets/icon.ico"
        Background="{StaticResource WindowBackgroundBrush}">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40"
                            ResizeBorderThickness="6"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Border Background="{StaticResource WindowBackgroundBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Grid Margin="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource PanelAltBrush}" CornerRadius="16" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="0,0,0,14">
                <Grid Height="54" Margin="12,0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="34" Height="34" Background="{StaticResource HeroBrush}" CornerRadius="10" Margin="0,0,12,0">
                            <Image Source="/Assets/icon.png" Stretch="Uniform" Margin="5"/>
                        </Border>
                        <StackPanel>
                            <TextBlock Text="{x:Static loc:AppText.AppName}" FontFamily="{StaticResource HeadingFont}" FontSize="18" FontWeight="SemiBold"/>
                            <TextBlock Text="{x:Static loc:AppText.WindowSubtitle}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button Content="_" Style="{StaticResource TitleBarButton}" Click="MinimizeButton_Click"/>
                        <Button Content="X" Style="{StaticResource TitleBarCloseButton}" Click="CloseButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{StaticResource SidebarBrush}" CornerRadius="24"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="0,0,16,0">
                    <StackPanel Margin="18">
                        <RadioButton Style="{StaticResource NavButton}" Content="{x:Static loc:AppText.NavFormatAt}"
                                     IsChecked="{Binding SelectedPageIndex, Converter={StaticResource EnumToBool}, ConverterParameter=0}"
                                     Command="{Binding NavigateFormatAtCommand}"/>
                        <RadioButton Style="{StaticResource NavButton}" Content="{x:Static loc:AppText.NavInstall}"
                                     IsChecked="{Binding SelectedPageIndex, Converter={StaticResource EnumToBool}, ConverterParameter=1}"
                                     Command="{Binding NavigateYukleCommand}"/>
                        <RadioButton Style="{StaticResource NavButton}" Content="{x:Static loc:AppText.NavOptimize}"
                                     IsChecked="{Binding SelectedPageIndex, Converter={StaticResource EnumToBool}, ConverterParameter=2}"
                                     Command="{Binding NavigateOptimizasyonCommand}"/>
                        <RadioButton Style="{StaticResource NavButton}" Content="{x:Static loc:AppText.NavInfo}"
                                     IsChecked="{Binding SelectedPageIndex, Converter={StaticResource EnumToBool}, ConverterParameter=3}"
                                     Command="{Binding NavigateInfoCommand}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="#120E1823" CornerRadius="24" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <ContentControl Content="{Binding CurrentPage}" Margin="0">
                        <ContentControl.Resources>
                            <DataTemplate DataType="{x:Type vm:FormatAtViewModel}">
                                <views:FormatAtView/>
                            </DataTemplate>
                            <DataTemplate DataType="{x:Type vm:YukleViewModel}">
                                <views:YukleView/>
                            </DataTemplate>
                            <DataTemplate DataType="{x:Type vm:OptimizasyonViewModel}">
                                <views:OptimizasyonView/>
                            </DataTemplate>
                            <DataTemplate DataType="{x:Type vm:InfoViewModel}">
                                <views:InfoView/>
                            </DataTemplate>
                        </ContentControl.Resources>
                    </ContentControl>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
