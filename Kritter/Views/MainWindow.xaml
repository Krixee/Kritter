<Window x:Class="Kritter.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Kritter.ViewModels"
        xmlns:views="clr-namespace:Kritter.Views"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Kritter" Width="1280" Height="820"
        MinWidth="1080" MinHeight="680"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Icon="/Assets/icon.ico"
        Background="{StaticResource WindowBackgroundBrush}">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40"
                            ResizeBorderThickness="6"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Border Background="{StaticResource WindowBackgroundBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Grid Margin="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource PanelAltBrush}" CornerRadius="16" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="0,0,0,14">
                <Grid Height="54" Margin="12,0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="34" Height="34" Background="{StaticResource HeroBrush}" CornerRadius="10" Margin="0,0,12,0">
                            <Image Source="/Assets/icon.png" Stretch="Uniform" Margin="5"/>
                        </Border>
                        <StackPanel>
                            <TextBlock Text="Kritter" FontFamily="{StaticResource HeadingFont}" FontSize="18" FontWeight="SemiBold"/>
                            <TextBlock Text="Post-format setup, restore and optimization console"
                                       FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Border Style="{StaticResource InfoPill}" Margin="0,0,10,0" VerticalAlignment="Center">
                            <TextBlock Text="v2.0" FontFamily="{StaticResource HeadingFont}" FontSize="11" Foreground="{StaticResource AccentBrush}"/>
                        </Border>
                        <Button Content="_" Style="{StaticResource TitleBarButton}" Click="MinimizeButton_Click"/>
                        <Button Content="X" Style="{StaticResource TitleBarCloseButton}" Click="CloseButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{StaticResource SidebarBrush}" CornerRadius="24"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="0,0,16,0">
                    <Grid Margin="18">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Style="{StaticResource HeroCard}" Margin="0,0,0,16">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="52" Height="52" CornerRadius="14" Background="{StaticResource AccentPanelBrush}" Margin="0,0,14,0">
                                        <Image Source="/Assets/icon.png" Stretch="Uniform" Margin="8"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Kritter" FontFamily="{StaticResource HeadingFont}" FontSize="24" FontWeight="SemiBold"/>
                                        <TextBlock Text="Release v2" Foreground="{StaticResource AccentBrush}" FontSize="12"/>
                                    </StackPanel>
                                </StackPanel>
                                <TextBlock Text="Fresh install sonrası uygulamaları, yerel setup dosyalarını, CS2 ayarlarını ve optimizasyon akışını tek pakette toparlar."
                                           Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,16,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1" Style="{StaticResource SectionCard}" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Workspace" FontFamily="{StaticResource HeadingFont}" FontSize="13" Foreground="{StaticResource AccentBrush}"/>
                                <TextBlock Text="Three guided flows" FontFamily="{StaticResource HeadingFont}" FontSize="20" Margin="0,8,0,6"/>
                                <TextBlock Text="Format At ile paket oluştur, Yükle ile geri kur, Optimizasyon ile doğrudan script çalıştır."
                                           Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <StackPanel Grid.Row="2">
                            <RadioButton Style="{StaticResource NavButton}" Content="Format At"
                                         IsChecked="{Binding SelectedPageIndex, Converter={StaticResource EnumToBool}, ConverterParameter=0}"
                                         Command="{Binding NavigateFormatAtCommand}"/>
                            <RadioButton Style="{StaticResource NavButton}" Content="Yükle"
                                         IsChecked="{Binding SelectedPageIndex, Converter={StaticResource EnumToBool}, ConverterParameter=1}"
                                         Command="{Binding NavigateYukleCommand}"/>
                            <RadioButton Style="{StaticResource NavButton}" Content="Optimizasyon"
                                         IsChecked="{Binding SelectedPageIndex, Converter={StaticResource EnumToBool}, ConverterParameter=2}"
                                         Command="{Binding NavigateOptimizasyonCommand}"/>
                        </StackPanel>

                        <Border Grid.Row="3" Style="{StaticResource SectionCard}" Margin="0,16,0,0">
                            <StackPanel>
                                <TextBlock Text="Notes" FontFamily="{StaticResource HeadingFont}" FontSize="13" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,8"/>
                                <TextBlock Text="Author: Krixe" Margin="0,0,0,6"/>
                                <TextBlock Text="Optimization scripts change Windows settings. A restore point is still the right baseline before use."
                                           Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,10"/>
                                <Border Style="{StaticResource InfoPill}" HorizontalAlignment="Left">
                                    <TextBlock Text="Windows setup companion" FontSize="11" Foreground="{StaticResource AccentBrush}"/>
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Background="#120E1823" CornerRadius="24" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <ContentControl Content="{Binding CurrentPage}" Margin="0">
                    <ContentControl.Resources>
                        <DataTemplate DataType="{x:Type vm:FormatAtViewModel}">
                            <views:FormatAtView/>
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:YukleViewModel}">
                            <views:YukleView/>
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:OptimizasyonViewModel}">
                            <views:OptimizasyonView/>
                        </DataTemplate>
                    </ContentControl.Resources>
                    </ContentControl>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
