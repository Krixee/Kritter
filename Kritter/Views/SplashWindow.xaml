<Window x:Class="Kritter.Views.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="520"
        Height="320"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        Icon="/Assets/icon.ico">
    <Border CornerRadius="24" Background="{StaticResource HeroBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border Width="128" Height="128" CornerRadius="32" Background="{StaticResource AccentPanelBrush}" Margin="0,0,0,18">
                    <Image Source="/Assets/icon.png" Width="92" Height="92" Stretch="Uniform" Margin="18"/>
                </Border>
                <TextBlock Text="Kritter" FontFamily="{StaticResource HeadingFont}" FontSize="32" FontWeight="Bold"
                           HorizontalAlignment="Center" Foreground="{StaticResource TextBrush}"/>
                <TextBlock Text="Release v2" FontSize="12" HorizontalAlignment="Center"
                           Foreground="{StaticResource AccentBrush}" Margin="0,6,0,0"/>
            </StackPanel>

            <TextBlock Grid.Row="1"
                       Text="Uygulamalar taranıyor..."
                       FontSize="14"
                       HorizontalAlignment="Center"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,8,0,0"/>
        </Grid>
    </Border>
</Window>
