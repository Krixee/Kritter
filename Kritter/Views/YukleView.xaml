<UserControl x:Class="Kritter.Views.YukleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgBrush}">

    <Grid Margin="32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Page Title -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Yükle" FontSize="22" FontWeight="Bold" Margin="0,0,0,4"/>
            <TextBlock Text="Bir .kritter paketi seçin ve yükleme işlemini başlatın."
                       Foreground="{StaticResource TextSecondaryBrush}"/>
        </StackPanel>

        <!-- Load Package -->
        <DockPanel Grid.Row="1" Margin="0,0,0,16">
            <Button Content="Paket Seç" Style="{StaticResource AccentButton}"
                    Command="{Binding LoadPackageCommand}" DockPanel.Dock="Left"/>
        </DockPanel>

        <!-- Package Info -->
        <Border Grid.Row="2" Background="{StaticResource CardBrush}" CornerRadius="8"
                Padding="16" Margin="0,0,0,16"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                Visibility="{Binding LoadedPackage, Converter={StaticResource NullToVis}}">
            <StackPanel>
                <TextBlock Text="Paket Bilgisi" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <TextBlock Text="{Binding PackageInfo}" Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Start Button -->
        <DockPanel Grid.Row="3" Margin="0,0,0,16"
                   Visibility="{Binding LoadedPackage, Converter={StaticResource NullToVis}}">
            <Button Content="Yüklemeyi Başlat" Style="{StaticResource AccentButton}"
                    Command="{Binding StartCommand}" DockPanel.Dock="Left"
                    FontSize="15" Padding="32,12"/>
            <TextBlock Text="{Binding CurrentStepText}" VerticalAlignment="Center"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="16,0,0,0"
                       FontSize="12"/>
        </DockPanel>

        <!-- Log Area -->
        <Border Grid.Row="4" Background="{StaticResource CardBrush}" CornerRadius="8"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                Padding="12" Margin="0,0,0,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="İşlem Günlüğü" FontSize="13"
                           FontWeight="SemiBold" Margin="0,0,0,8"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
                <ListBox x:Name="LogList" ItemsSource="{Binding LogEntries}"
                         Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         FontFamily="Cascadia Mono, Consolas, Courier New"
                         FontSize="12" Foreground="{StaticResource TextBrush}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" TextWrapping="Wrap" Margin="0,1"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Running indicator -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="0,8,0,0"
                    Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="&#x23F3;" FontSize="14" Margin="0,0,6,0"/>
            <TextBlock Text="İşlem devam ediyor..." Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
        </StackPanel>

        <!-- Restart button (shown after optimization completes) -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="0,8,0,0"
                    Visibility="{Binding IsWaitingForRestart, Converter={StaticResource BoolToVis}}">
            <Button Content="Yeniden Başlat" Style="{StaticResource AccentButton}"
                    Command="{Binding RestartCommand}" FontSize="15" Padding="32,12"/>
            <TextBlock Text="Yeniden başlatma bekleniyor..." VerticalAlignment="Center"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="16,0,0,0" FontSize="12"/>
        </StackPanel>
    </Grid>
</UserControl>
