<UserControl x:Class="Kritter.Views.YukleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:Kritter.Localization"
             Background="Transparent">

    <Grid Margin="28,26">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource HeroCard}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="{x:Static loc:AppText.InstallPageTitle}" Style="{StaticResource PageTitleText}"/>
                    <TextBlock Text="{x:Static loc:AppText.InstallPageSubtitle}"
                               Style="{StaticResource PageSubtitleText}" Margin="0,8,0,0" MaxWidth="680"/>

                    <WrapPanel Margin="0,20,0,0">
                        <Border Style="{StaticResource MetricCard}" Width="180">
                            <StackPanel>
                                <TextBlock Text="{x:Static loc:AppText.PackageStatus}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                                <TextBlock Text="{Binding PackageStatusSummary}" FontFamily="{StaticResource HeadingFont}" FontSize="24"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource MetricCard}" Width="180">
                            <StackPanel>
                                <TextBlock Text="{x:Static loc:AppText.ExecutionState}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                                <TextBlock Text="{Binding ExecutionStateSummary}" FontFamily="{StaticResource HeadingFont}" FontSize="24"/>
                            </StackPanel>
                        </Border>
                    </WrapPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" VerticalAlignment="Top">
                    <Button Content="{x:Static loc:AppText.SelectPackage}" Style="{StaticResource AccentButton}"
                            Command="{Binding LoadPackageCommand}" MinWidth="150"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource SectionCard}"
                Visibility="{Binding LoadedPackage, Converter={StaticResource NullToVis}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="{x:Static loc:AppText.PackageInfoTitle}" FontFamily="{StaticResource HeadingFont}" FontSize="18" Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding PackageInfo}" Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="13" TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="18,0,0,0" VerticalAlignment="Center">
                    <Button Content="{x:Static loc:AppText.StartInstall}" Style="{StaticResource AccentButton}"
                            Command="{Binding StartCommand}" FontSize="15" Padding="32,14"/>
                    <TextBlock Text="{Binding CurrentStepText}" VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,12,0,0"
                               FontSize="12" Width="220" TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource SectionCard}"
                Visibility="{Binding IsWaitingForRestart, Converter={StaticResource BoolToVis}}">
            <StackPanel Orientation="Horizontal">
                <Button Content="{x:Static loc:AppText.RestartNow}" Style="{StaticResource AccentButton}"
                        Command="{Binding RestartCommand}" FontSize="15" Padding="32,14"/>
                <TextBlock Text="{x:Static loc:AppText.RestartWaiting}"
                           VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="16,0,0,0" FontSize="12"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="3" Style="{StaticResource SectionCard}">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                    <TextBlock Text="{x:Static loc:AppText.OperationLog}" FontFamily="{StaticResource HeadingFont}" FontSize="18"/>
                    <TextBlock Text="{x:Static loc:AppText.OperationLogSubtitle}"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>

                <ListBox x:Name="LogList" ItemsSource="{Binding LogEntries}"
                         Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         FontFamily="{StaticResource MonoFont}"
                         FontSize="12" Foreground="{StaticResource TextBrush}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" TextWrapping="Wrap" Margin="0,2"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,8,0,0"
                    Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}">
            <Border Style="{StaticResource InfoPill}">
                <TextBlock Text="{x:Static loc:AppText.LiveExecution}" FontSize="11" Foreground="{StaticResource AccentBrush}"/>
            </Border>
            <TextBlock Text="{x:Static loc:AppText.ProcessRunning}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="10,2,0,0"/>
        </StackPanel>
    </Grid>
</UserControl>
